{
  "manifest_version": 3,
  "name": "Zombie!",
  "version": "1.0",
  "description": "Spawn zombies that crash into each other!",
  "action": {
    "default_icon": "zombie.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}